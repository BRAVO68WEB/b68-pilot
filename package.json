{
  "name": "gh-pilot",
  "module": "index.ts",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:core && bun run build:cli && bun run build:worker",
    "build:cli": "cd packages/cli && bun run build",
    "build:worker": "cd packages/worker && bun run build",
    "build:core": "cd packages/core && bun run build",
    "build:dashboard": "cd packages/dashboard && bun run build",
    "dev:dashboard": "cd packages/dashboard && bun run dev",
    "dev:worker": "cd packages/worker && bun run webhook",
    "test": "cd packages/core && bun test"
  },
  "dependencies": {
    "typescript": "^5.0.0"
  }
}